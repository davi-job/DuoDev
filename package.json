    "bugs": {
        "url": "https://github.com/davi-job/DuoDev/issues"
    },
    "homepage": "https://github.com/davi-job/DuoDev#readme",
    "workspaces": [
        "apps/*",
        "apps/admin/*",
        "packages/*"
    ],
    "dependencies": {
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.1",
        "pg": "^8.20.0"
    },
    "devDependencies": {
